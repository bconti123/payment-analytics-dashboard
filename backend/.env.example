# --- Database ---
# Default: TCP connection with username/password.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/payment_analytics

# Alternative for local Linux dev using Postgres peer auth (no password):
# DATABASE_URL=postgresql+psycopg2://your_unix_user@/payment_analytics

# --- App ---
DEBUG=false

# --- Claude API (optional) ---
# Required for the AI weekly insight endpoint. Leave unset to disable.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Required in any deployed environment. The default is for local dev only.
JWT_SECRET=dev-only-do-not-use-in-production-change-me-please
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TTL_MINUTES=60
